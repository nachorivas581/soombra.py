  const [recents, setRecents] = useState<Canal[]>([]);
  const [numeroMarcado, setNumeroMarcado] = useState('');
  const [errorCanal, setErrorCanal] = useState(false);
  const [forceWebView, setForceWebView] = useState(false);
  const [webViewExtractor, setWebViewExtractor] = useState<string | null>(null);
  const [useWebViewPlayer, setUseWebViewPlayer] = useState(false);
  const [webViewPlayerUrl, setWebViewPlayerUrl] = useState<string | null>(null);
  const [autoFullscreen, setAutoFullscreen] = useState(false);
  const [streamError, setStreamError] = useState<string | null>(null);

  // ========== REFS ==========
  const canalRef = useRef<Canal | null>(null);
  const embedWebViewRef = useRef<WebView>(null);
  const webViewRef = useRef<WebView>(null);
  const webViewExtractorRef = useRef<WebView>(null);
  const timerCaza = useRef<ReturnType<typeof setTimeout> | null>(null);
  const timerZap = useRef<ReturnType<typeof setTimeout> | null>(null);
  const inputRef = useRef<TextInput>(null);
  const liveDot = useRef(new Animated.Value(1)).current;
  const panRef = useRef<any>(null);
  const pendingResolve = useRef<((stream: string) => void) | null>(null);
  const streamFoundRef = useRef(false);

  const MAX_SOURCES = 5;

  // ========== FUNCIONES AUXILIARES ==========
  const limpiarCaza = () => {
    if (timerCaza.current) {
      clearTimeout(timerCaza.current);
      timerCaza.current = null;
    }
  };

  const alMarcarNumero = (txt: string) => {
    const n = txt.replace(/[^0-9]/g, '');
    if (!n) return;
    setNumeroMarcado(n);
    if (timerZap.current) clearTimeout(timerZap.current);
    timerZap.current = setTimeout(() => {
      const found = listaCanales.find(c => c.numero === parseInt(n, 10));
      if (found) sintonizar(found);
      else {
        setErrorCanal(true);
        setTimeout(() => setErrorCanal(false), 1800);
      }
      setNumeroMarcado('');
    }, 1400);
  };

  const esUrlWeb = (url: string): boolean => {
    if (!url) return false;
    const lower = url.toLowerCase();
    return (
      lower.includes('gambeta.vip') ||
      lower.includes('librepelota.su') ||
      lower.includes('streamhdx.com') ||
      lower.includes('streamtp') ||
      lower.includes('embed.saohgdasregions.fun') ||
      lower.includes('regionales.saohgdasregions.fun') ||
      (!esUrlManifiesto(url) && (lower.startsWith('http') && !lower.endsWith('.m3u8') && !lower.endsWith('.mpd')))
    );
  };

  const extraerSlugDeUrlWeb = (url: string): string | null => {
    const patterns = [
      /stream=([^&]+)/i,
      /canal=([^&]+)/i,
      /\/canal\/([^\/]+)/i,
      /\/es\/([^\/]+)/i,
      /embed2\/([^\/]+)\.html/i,
    ];
    for (const pattern of patterns) {
      const match = url.match(pattern);
      if (match) return match[1];
    }
    return null;
  };

  // generarUrlsAlternativas (definida dentro del componente)
  const generarUrlsAlternativas = (slug: string): string[] => {
    const urls: string[] = [];
    if (!slug) return urls;
    urls.push(`https://streamhdx.com/live1.php?stream=${slug}`);
    const slugMapGambeta: Record<string, string> = {
      'dsports': 'directv-sports',
      'dsports2': 'directv-sports-2',
      'dsportsplus': 'directv-sports-plus',
      'tycsports': 'tyc-sports',
      'tntsports': 'tnt-sports',
      'espn': 'espn',
      'espn2': 'espn-2',
      'espn3': 'espn-3',
      'espn4': 'espn-4',
      'espn5': 'espn-5',
      'espn6': 'espn-6',
      'discoveryscience': 'discovery-science',
      'universalpremiere': 'universal-premiere',
      'movistarligadecampeones':'movistar-liga-de-campeones',
      'tudn' : 'tudn',
      'beinsportsxtra':'bein-sports-xtra',
    };
    const mappedGambeta = slugMapGambeta[slug] || slug;
    urls.push(`https://gambeta.vip/canal/${mappedGambeta}`);
    urls.push(`https://embed.saohgdasregions.fun/embed2/${slug}.php`);
    urls.push(`https://librepelota.su/es/${slug}/`);
    return urls;
  };

  const agregarFuenteConLimite = (sources: string[], url: string): string[] => {
    if (!url || sources.includes(url)) return sources;
    if (sources.length >= MAX_SOURCES) return sources;
    try {
      const domain = new URL(url).hostname;
      const existsSimilar = sources.some(s => {
        try { return new URL(s).hostname === domain; } catch { return false; }
      });
      if (existsSimilar) return sources;
    } catch {}
    return [...sources, url];
  };

  // ========== EXTRACCIÓN DESDE WEB ==========
  const extraerStreamDesdeWeb = async (url: string, embedSlug?: string): Promise<string | null> => {
    const slug = embedSlug || extraerSlugDeUrlWeb(url) || '';
    console.log('[LivePlayer] Extrayendo desde web:', url, 'slug:', slug);

    const esGambeta = url.includes('gambeta.vip');
    if (esGambeta) {
      console.log('[LivePlayer] Usando extractor deportivo para gambeta.vip');
      const stream = await obtenerStreamDeportes(slug, url);
      if (stream) return stream;
    }

    const esDeportivo = slug && ['dsports', 'tycsports', 'espn', 'tntsports', 'clarosports', 'discovery-science', 'universal-premiere','movistar-liga-de-campeones','bein-sports-xtra','tudn',].some(s => slug.includes(s));
    if (esDeportivo && slug) {
      const stream = await obtenerStreamDeportes(slug, url);
      if (stream) return stream;
      console.log('[LivePlayer] Falló extractor deportivo para URL específica, usando WebView extractor...');
      return new Promise<string | null>((resolve) => {
        streamFoundRef.current = false;
        pendingResolve.current = resolve;
        setWebViewExtractor(url);
        setTimeout(() => {
          if (pendingResolve.current) {
            pendingResolve.current(null);
            pendingResolve.current = null;
            setWebViewExtractor(null);
          }
        }, 15000);
      });
    }

    if (slug) {
      const stream = await obtenerStreamTNT(slug, url, 0);
      if (stream) return stream;
    }

    return new Promise<string | null>((resolve) => {
      streamFoundRef.current = false;
      pendingResolve.current = resolve;
      setWebViewExtractor(url);
      setTimeout(() => {
        if (pendingResolve.current) {
          pendingResolve.current(null);
          pendingResolve.current = null;
          setWebViewExtractor(null);
        }
      }, 15000);
    });
  };

  // ========== CAMBIAR FUENTE (con WebView forzado para gambeta) ==========
  const cambiarFuente = async (idx: number) => {
    if (!canalRef.current || !canalRef.current.sources) return;
    const url = canalRef.current.sources[idx];
    if (!url) return;

    setCurrentSourceIndex(idx);
    setEmbedBuscando(true);
    setLinkM3u8(null);
    setUseWebViewPlayer(false);
    setWebViewPlayerUrl(null);
    setUseEmbedPlayer(false);
    setStreamError(null);

    if (esUrlManifiesto(url)) {
      // Si es gambeta, forzar WebViewPlayer
      if (url.includes('gambeta.vip') || url.includes('cdn.gambeta.vip')) {
        console.log('[LivePlayer] Fuente gambeta, usando WebViewPlayer');
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(url);
        setEmbedBuscando(false);
        return;
      }
      setLinkM3u8(url);
      setEmbedBuscando(false);
      return;
    }

    if (esUrlWeb(url)) {
      const c = canalRef.current;
      const slug = c?.embedSlug || extraerSlugDeUrlWeb(url) || '';
      const stream = await extraerStreamDesdeWeb(url, slug);
      if (stream) {
        const esDeportivo = slug && ['dsports', 'tycsports', 'espn', 'tntsports', 'clarosports', 'discovery-science', 'universal-premiere'].some(s => slug.includes(s));
        // Si es gambeta, forzar WebViewPlayer
        if (url.includes('gambeta.vip') || stream.includes('gambeta.vip') || stream.includes('cdn.gambeta.vip')) {
          console.log('[LivePlayer] Stream de gambeta, usando WebViewPlayer');
          setUseWebViewPlayer(true);
          setWebViewPlayerUrl(stream);
        } else if (esDeportivo) {
          setUseWebViewPlayer(true);
          setWebViewPlayerUrl(stream);
        } else {
          setLinkM3u8(stream);
        }
        setEmbedBuscando(false);
        return;
      } else {
        setStreamError('No se pudo obtener el stream de esta fuente');
        setEmbedBuscando(false);
        return;
      }
    } else {
      const c = canalRef.current;
      const slug = c?.embedSlug || extraerSlugDeUrlWeb(url) || '';
      if (slug) {
        const stream = await obtenerStreamTNT(slug, url, 0);
        if (stream) {
          // Si es gambeta, forzar WebViewPlayer
          if (stream.includes('gambeta.vip') || stream.includes('cdn.gambeta.vip')) {
            setUseWebViewPlayer(true);
            setWebViewPlayerUrl(stream);
          } else {
            setLinkM3u8(stream);
          }
          setEmbedBuscando(false);
          return;
        }
      }
      setStreamError('La URL no es válida o no se pudo reproducir');
      setEmbedBuscando(false);
    }
  };

  const abrirFullscreen = () => {
    if (!linkM3u8 && !useEmbedPlayer && !useWebViewPlayer) {
      if (streamError) Alert.alert('Error', streamError);
      return;
    }
    setFullscreen(true);
    Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Medium);
  };

  const canalSiguiente = () => {
    const lista = listaCanales;
    if (!canal || !lista.length) return;
    const idx = lista.findIndex(c => c.id === canal.id);
    sintonizar(lista[(idx + 1) % lista.length]);
