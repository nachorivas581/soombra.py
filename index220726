      {webViewExtractor && (
        <WebView
          ref={webViewExtractorRef}
          source={{ uri: webViewExtractor }}
          originWhitelist={['*']}
          javaScriptEnabled
          domStorageEnabled
          mediaPlaybackRequiresUserAction={false}
          allowsInlineMediaPlayback
          mixedContentMode="always"
          style={{ position: 'absolute', width: 1, height: 1, opacity: 0 }}
          onMessage={async (e) => {
            if (streamFoundRef.current) return;
            const data = e.nativeEvent.data;
            if (data && data.startsWith('FOUND_MANIFEST:')) {
              const stream = data.replace('FOUND_MANIFEST:', '');
              if (stream && stream.startsWith('http')) {
                streamFoundRef.current = true;
                console.log('[WebViewExtractor] Stream encontrado:', stream);
                if (pendingResolve.current) {
                  pendingResolve.current(stream);
                  pendingResolve.current = null;
                }
                if (stream.includes('gambeta.vip') || stream.includes('cdn.gambeta.vip')) {
                  setUseWebViewPlayer(true);
                  setWebViewPlayerUrl(stream);
                } else {
                  setLinkM3u8(stream);
                }
                setEmbedBuscando(false);
                setWebViewExtractor(null);
              }
            }
          }}
          injectedJavaScriptBeforeContentLoaded={TNT_INJECTION_BEFORE}
          injectedJavaScript={`
            ${TNT_INJECTION_AFTER}
            (function() {
              function searchInHTML() {
                var html = document.documentElement.innerHTML;
                var match = html.match(/(?:https?:)?\\/\\/[^\\s"'<>]+\\.m3u8[^\\s"'<>]*/);
                if (match) {
                  window.ReactNativeWebView.postMessage('FOUND_MANIFEST:' + match[0]);
                }
              }
              setTimeout(searchInHTML, 3000);
              setTimeout(searchInHTML, 6000);
            })();
          `}
        />
      )}
    </View>
  );
});
