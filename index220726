async function obtenerStreamTNT(
  embedSlug: string,
  urlBase?: string,
  retryCount = 0
): Promise<string | null> {
  const MAX_RETRIES = 3;
  const delay = (ms: number) => new Promise(r => setTimeout(r, ms));

  // Mapeo de slugs a URLs amigables en vertvcable.com (puedes ampliarlo)
  const vertvcableSlugs: Record<string, string> = {
    'universalpremiere': 'universal-premiere-en-vivo',
    // Agrega más según necesites
  };

  const posiblesUrls: string[] = [];

  // 1. URL base (si se proporciona)
  if (urlBase) {
    posiblesUrls.push(urlBase);
  }

  // 2. Dominios conocidos (los que ya tenía)
  posiblesUrls.push(
    `https://streamhdx.com/live1.php?stream=${embedSlug}`,
    `https://regionales.saohgdasregions.fun/stream.php?canal=${embedSlug}`,
    `https://embed.saohgdasregions.fun/embed2/${embedSlug}.php`,
    `https://streamhdx.com/live1.php?stream=${embedSlug}&hd=1`,
  );

  // 3. vertvcable.com (si existe un mapeo para este slug)
  if (vertvcableSlugs[embedSlug]) {
    posiblesUrls.push(
      `https://www.vertvcable.com/${vertvcableSlugs[embedSlug]}/`
    );
  }

  // Eliminar duplicados y URLs vacías
  const urlsToTry = [...new Set(posiblesUrls)].filter(u => u && u.length > 0);

  for (let intento = 0; intento <= retryCount; intento++) {
    for (const url of urlsToTry) {
      try {
        console.log(`[TNT] Intentando extraer de: ${url}`);
        const res = await fetch(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
            'Referer': 'https://embed.saohgdasregions.fun/',
            'Origin': 'https://embed.saohgdasregions.fun',
          },
        });
        const html = await res.text();

        // --- Estrategia 1: JWPlayer ---
        const jwRegex = /jwplayer\s*\(\s*["'][^"']*["']\s*\)\s*\.setup\s*\(\s*\{[^}]*playlist\s*:\s*\[\s*\{[^}]*file\s*:\s*["']([^"']+)["']/is;
        const match = html.match(jwRegex);
        if (match) {
          const rawUrl = match[1];
          const normalized = normalizarUrl(rawUrl);
          console.log(`[TNT] Stream encontrado en JWPlayer: ${normalized}`);
          return normalized;
        }

        // --- Estrategia 2: iframe anidado (buscar src y seguir) ---
        const iframeMatch = html.match(/<iframe[^>]*src=["']([^"']+)["']/i);
        if (iframeMatch) {
          const iframeUrl = iframeMatch[1];
          if (iframeUrl && !iframeUrl.startsWith('http')) {
            // Si es relativo, construir URL absoluta
            const base = new URL(url);
            const fullIframeUrl = new URL(iframeUrl, base.origin).href;
            // Seguir el iframe
            const stream = await extraerStreamDesdeIframe(fullIframeUrl);
            if (stream) return stream;
          } else {
            const stream = await extraerStreamDesdeIframe(iframeUrl);
            if (stream) return stream;
          }
        }

        // --- Estrategia 3: playbackURL (script) ---
        const playbackMatch = html.match(/playbackURL\s*=\s*["']([^"']+)["']/);
        if (playbackMatch && playbackMatch[1]) {
          const normalized = normalizarUrl(playbackMatch[1]);
          console.log(`[TNT] Stream encontrado (playbackURL): ${normalized}`);
          return normalized;
        }

        // --- Estrategia 4: source en Clappr ---
        const sourceMatch = html.match(/source\s*:\s*["']([^"']+)["']/);
        if (sourceMatch && sourceMatch[1]) {
          const normalized = normalizarUrl(sourceMatch[1]);
          console.log(`[TNT] Stream encontrado (source): ${normalized}`);
          return normalized;
