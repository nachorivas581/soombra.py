const doramasLoaded = useRef(false);
  const [listaCanales, setListaCanales] = useState<Canal[]>([]);

// ===== CARGA DE ANIME (con caché persistente) =====
const cargarAnime = useCallback(async (force = false) => {
  if (loadingAnime) return;
  if (!force && animeLoaded.current) return;

  // Intenta cargar desde la caché de shows (si existe y no es force)
  if (!force) {
    try {
      const cached = await AsyncStorage.getItem('driveAnimeShowsCache');
      if (cached) {
        const shows = JSON.parse(cached);
        setAnimeShows(shows);
        animeLoaded.current = true;
        return;
      }
    } catch (e) {
      console.warn('Error al leer caché de Anime:', e);
    }
  }

  // Si no hay caché o se fuerza, escanea Drive
  setLoadingAnime(true);
  try {
    const shows = await cargarSeriesPlex(DRIVE_FOLDER_ANIME, 'driveAnimeCache');
    setAnimeShows(shows);
    // Guarda la lista completa de shows en AsyncStorage
    await AsyncStorage.setItem('driveAnimeShowsCache', JSON.stringify(shows));
    animeLoaded.current = true;
  } catch (e) {
    console.error('Error al cargar Anime:', e);
  } finally {
    setLoadingAnime(false);
  }
}, [loadingAnime]);

// ===== CARGA DE DORAMAS (con caché persistente) =====
const cargarDoramas = useCallback(async (force = false) => {
  if (loadingDoramas) return;
  if (!force && doramasLoaded.current) return;

  // Intenta cargar desde la caché de shows (si existe y no es force)
  if (!force) {
    try {
      const cached = await AsyncStorage.getItem('driveDoramasShowsCache');
      if (cached) {
        const shows = JSON.parse(cached);
        setDoramasShows(shows);
        doramasLoaded.current = true;
        return;
      }
    } catch (e) {
      console.warn('Error al leer caché de Doramas:', e);
    }
  }

  // Si no hay caché o se fuerza, escanea Drive
  setLoadingDoramas(true);
  try {
    const shows = await cargarSeriesPlex(DRIVE_FOLDER_DORAMAS, 'driveDoramasCache');
    setDoramasShows(shows);
    // Guarda la lista completa de shows en AsyncStorage
    await AsyncStorage.setItem('driveDoramasShowsCache', JSON.stringify(shows));
