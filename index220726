    if (favorites.length > 0) cats.add('Favoritos');
    setCategorias(Array.from(cats));
    if (!canal && listaCanales.length > 0) {
      console.log('[LivePlayer] Seleccionando primer canal por defecto');
      sintonizar(listaCanales[0]);
    }
  }, [listaCanales]);

  useEffect(() => {
    const pulse = Animated.loop(Animated.sequence([
      Animated.timing(liveDot, { toValue: 0.15, duration: 800, useNativeDriver: true }),
      Animated.timing(liveDot, { toValue: 1, duration: 800, useNativeDriver: true }),
    ]));
    pulse.start();
    return () => pulse.stop();
  }, []);

  useEffect(() => {
    if (webViewExtractor) {
      const timer = setTimeout(() => {
        console.log('[WebViewExtractor] Timeout, no se encontró stream.');
        if (pendingResolve.current) {
          pendingResolve.current(null);
          pendingResolve.current = null;
        }
        setWebViewExtractor(null);
        setEmbedBuscando(false);
      }, 15000);
      return () => clearTimeout(timer);
    }
  }, [webViewExtractor]);

  // ========== PAN RESPONDER ==========
  if (!panRef.current) {
    const lastTapRef = { current: null as number | null };
