                    </head>
                    <body>
                      <video id="video" controls autoplay playsinline muted></video>
                      <script>
                        var video = document.getElementById('video');
                        var streamUrl = '${webViewPlayerUrl}';
                        var isGambeta = ${webViewPlayerUrl.includes('gambeta.vip') || webViewPlayerUrl.includes('cdn.gambeta.vip')};
                        if (Hls.isSupported()) {
                          var hls = new Hls({
                            enableWorker: false,
                            maxBufferLength: 30,
                            xhrSetup: function(xhr, url) {
                              if (isGambeta) {
                                xhr.setRequestHeader('Referer', 'https://gambeta.vip/');
                                xhr.setRequestHeader('Origin', 'https://gambeta.vip');
                                xhr.setRequestHeader('User-Agent', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36');
                              }
                            }
                          });
                          hls.loadSource(streamUrl);
                          hls.attachMedia(video);
                          hls.on(Hls.Events.MANIFEST_PARSED, function() {
                            video.muted = true;
                            video.play().catch(function(e) {
                              setTimeout(function() { video.play().catch(function() {}); }, 500);
                            });
                          });
                          hls.on(Hls.Events.ERROR, function(event, data) {
                            if (data.fatal) {
                              setTimeout(function() { window.location.reload(); }, 3000);
                            }
                          });
                        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                          video.src = streamUrl;
                          video.addEventListener('loadedmetadata', function() { video.play(); });
                        } else {
                          document.body.innerHTML = '<p style="color:white;text-align:center;margin-top:40%;">Reproductor no compatible</p>';
                        }
                        // Monitoreo de congelamiento
                        var lastTime = 0;
                        var stuckCount = 0;
                        setInterval(function() {
                          if (video.currentTime === lastTime) {
                            stuckCount++;
                            if (stuckCount > 10) {
                              window.location.reload();
                            }
                          } else {
                            stuckCount = 0;
                            lastTime = video.currentTime;
                          }
                        }, 3000);
                      </script>
                    </body>
                    </html>
                  `
                }}
