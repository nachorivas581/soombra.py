          const wvStream = await new Promise<string | null>((resolve) => {
            pendingResolve.current = resolve;
            setWebViewExtractor(c.url);
            setTimeout(() => {
              if (pendingResolve.current) {
                pendingResolve.current(null);
                pendingResolve.current = null;
                setWebViewExtractor(null);
              }
            }, 15000);
          });
          setWebViewExtractor(null);
          if (wvStream) stream = wvStream;
        }
      } else {
        stream = await obtenerStreamTNT(slug, c.url, 0);
      }

      if (stream) {
        console.log('[LivePlayer] Stream obtenido exitosamente.');
        if (!c.sources.includes(stream) && c.sources.length < MAX_SOURCES) {
          c.sources.push(stream);
        }
        // Forzar WebView si es gambeta
        if (stream.includes('gambeta.vip') || stream.includes('cdn.gambeta.vip')) {
          console.log('[LivePlayer] Stream de gambeta, usando WebViewPlayer');
          setUseWebViewPlayer(true);
          setWebViewPlayerUrl(stream);
          setEmbedBuscando(false);
          setLinkM3u8(null);
        } else if (esDeportivo) {
          console.log('[LivePlayer] Usando WebView reproductor para deportivo.');
          setUseWebViewPlayer(true);
          setWebViewPlayerUrl(stream);
          setEmbedBuscando(false);
          setLinkM3u8(null);
        } else {
          setLinkM3u8(stream);
          setEmbedBuscando(false);
        }
        return;
      } else {
        console.log(`[LivePlayer] Falló extracción. ${attempt + 1 >= MAX_ATTEMPTS ? 'Máximo de intentos alcanzado.' : 'Reintentando en 3s...'}`);
        setEmbedBuscando(false);
        if (attempt + 1 < MAX_ATTEMPTS) {
          if (timerCaza.current) clearTimeout(timerCaza.current);
          timerCaza.current = setTimeout(() => {
            if (canalRef.current) sintonizar(canalRef.current, attempt + 1);
          }, 3000);
        } else {
          if (c.needsWebView || c.embedSlug) {
            console.log(`[LivePlayer] Activando embed directo para ${c.name}`);
            setUseEmbedPlayer(true);
            setEmbedBuscando(false);
          } else {
            setLinkM3u8(null);
            setUseWebViewPlayer(false);
            setWebViewPlayerUrl(null);
          }
        }
        return;
      }
    }

    // CASO 2: Canal SIN embedSlug
    console.log('[LivePlayer] Caso sin embedSlug (canal M3U/URL directa)');

    if (esUrlManifiesto(c.url)) {
      console.log('[LivePlayer] URL es manifiesto, reproduciendo directamente');
      if (!c.sources.includes(c.url) && c.sources.length < MAX_SOURCES) {
        c.sources.push(c.url);
      }
      if (c.url.includes('gambeta.vip') || c.url.includes('cdn.gambeta.vip')) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(c.url);
      } else {
        setLinkM3u8(c.url);
      }
      return;
    }

    console.log('[LivePlayer] URL no es manifiesto, intentando extraer con WebView...');
    setCazando(true);
    setEmbedBuscando(true);

    try {
      const stream = await new Promise<string | null>((resolve) => {
        streamFoundRef.current = false;
        pendingResolve.current = resolve;
        setWebViewExtractor(c.url);
        setTimeout(() => {
          if (pendingResolve.current) {
            pendingResolve.current(null);
            pendingResolve.current = null;
            setWebViewExtractor(null);
          }
        }, 15000);
      });
      setWebViewExtractor(null);
      setCazando(false);
      setEmbedBuscando(false);

      if (stream) {
        console.log('[LivePlayer] Stream extraído con WebView:', stream);
        if (!c.sources.includes(stream) && c.sources.length < MAX_SOURCES) {
          c.sources.push(stream);
        }
        if (stream.includes('gambeta.vip') || stream.includes('cdn.gambeta.vip')) {
          setUseWebViewPlayer(true);
          setWebViewPlayerUrl(stream);
        } else {
          setLinkM3u8(stream);
        }
        return;
      } else {
        console.log('[LivePlayer] No se pudo extraer stream con WebView.');
        setStreamError('No se pudo obtener el stream de este canal');
        setLinkM3u8(null);
        if (c.url) {
          console.log('[LivePlayer] Usando URL original como fallback');
          if (c.url.includes('gambeta.vip') || c.url.includes('cdn.gambeta.vip')) {
            setUseWebViewPlayer(true);
            setWebViewPlayerUrl(c.url);
          } else {
            setLinkM3u8(c.url);
          }
        }
        return;
      }
    } catch (e) {
      console.warn('[LivePlayer] Error en extracción WebView:', e);
      setCazando(false);
      setEmbedBuscando(false);
      setStreamError('Error al extraer el stream');
      setLinkM3u8(null);
    }
  };

  // ========== EFECTOS ==========
  useEffect(() => { canalRef.current = canal; }, [canal]);

  useEffect(() => {
    if (preselectedChannel) {
      setAutoFullscreen(true);
      sintonizar(preselectedChannel);
      clearPreselectedChannel?.();
