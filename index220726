  const [loadingPlex, setLoadingPlex] = useState(false);
  const [continueWatching, setContinueWatching] = useState<ContinueWatchingItem[]>([]);
  const [globalSearchVisible, setGlobalSearchVisible] = useState(false);
  const [showStats, setShowStats] = useState(false);

  // --- NUEVO: estado para canal preseleccionado desde búsqueda ---
  const [preselectedChannel, setPreselectedChannel] = useState<Canal | null>(null);

  const driveMoviesLoaded = useRef(false);
  const plexLoaded = useRef(false);
  const primaryColor = ACCENT_COLORS[activeProfile.accentColor] || ACCENT_COLORS.red;
  const cargaEnCurso = useRef(false);

  // Bloquear orientación vertical al inicio
  useEffect(() => {
    lockPortrait();
  }, []);

  // Cargar continue watching al cambiar de perfil
  useEffect(() => {
    getContinueWatching(activeProfile.id).then(setContinueWatching);
  }, [activeProfile.id]);

  const addToContinueWatching = useCallback((item: ContinueWatchingItem) => {
    setContinueWatching(prev => [item, ...prev.filter(i => i.id !== item.id)].slice(0, 20));
  }, []);

  // --- ANIMACIÓN DE SPLASH ---
  const splashOp = useRef(new Animated.Value(0)).current;
  const splashSc = useRef(new Animated.Value(0.94)).current;
  const ringRot = useRef(new Animated.Value(0)).current;
  const glowPulse = useRef(new Animated.Value(0.88)).current;
  const progressA = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    StatusBar.setBarStyle('light-content');
    Animated.parallel([
      Animated.timing(splashOp, { toValue: 1, duration: 700, easing: Easing.out(Easing.cubic), useNativeDriver: true }),
      Animated.timing(splashSc, { toValue: 1, duration: 700, easing: Easing.out(Easing.cubic), useNativeDriver: true })
    ]).start();

    const rot = Animated.loop(Animated.timing(ringRot, { toValue: 1, duration: 4000, easing: Easing.linear, useNativeDriver: true }));
    const glow = Animated.loop(Animated.sequence([
      Animated.timing(glowPulse, { toValue: 1.14, duration: 1000, easing: Easing.inOut(Easing.sin), useNativeDriver: true }),
      Animated.timing(glowPulse, { toValue: 0.84, duration: 1000, easing: Easing.inOut(Easing.sin), useNativeDriver: true })
    ]));
    rot.start();
    glow.start();

    Animated.timing(progressA, { toValue: 1, duration: 2400, easing: Easing.inOut(Easing.cubic), useNativeDriver: false }).start();

    const t = setTimeout(() => {
      Animated.parallel([
        Animated.timing(splashOp, { toValue: 0, duration: 350, useNativeDriver: true }),
        Animated.timing(splashSc, { toValue: 1.05, duration: 350, useNativeDriver: true })
      ]).start(() => {
        setSplash(false);
        setProfileSelection(true);
      });
    }, 2800);

    return () => {
      clearTimeout(t);
      rot.stop();
      glow.stop();
    };
  }, []);

  // --- CARGA DE LISTA M3U ---
  const cargarListaM3U = useCallback(async () => {
    if (cargaEnCurso.current) return;
    cargaEnCurso.current = true;
    setLoadingChannels(true);
    for (let i = 0; i < 3; i++) {
      try {
        const res = await fetch(`${M3U_URL}?t=${Date.now()}`, { cache: 'no-store' });
        const txt = await res.text();
        const lineas = txt.split('\n');
        const parsed: Canal[] = [];
        let info = { name: '', logo: '', category: 'General' };
        let idx = 20;
        lineas.forEach(l => {
          const lim = l.trim();
          if (lim.startsWith('#EXTINF:')) {
            const parts = lim.split(',');
            info.name = parts[parts.length - 1].trim() || 'Canal';
            info.logo = lim.match(/tvg-logo="([^"]+)"/i)?.[1] ?? '';
            info.category = lim.match(/group-title="([^"]+)"/i)?.[1] ?? 'General';
          } else if (lim.startsWith('http')) {
            let url = convertirMpdAHls(lim);
            const slug = extractEmbedSlug(url);
            const isEmbed = slug && (url.includes('streamtpday1') || url.includes('saohgdasregions') || url.includes('streamhdx'));
            parsed.push({
              id: String(3000 + idx),
              numero: idx++,
              name: info.name,
              logo: info.logo,
              category: info.category,
              url,
              ...(isEmbed ? { embedSlug: slug!, needsWebView: true } : {})
            });
            info = { name: '', logo: '', category: 'General' };
          }
        });
        setListaCanales([...CANALES_MANUALES, ...parsed]);
        break;
      } catch {
        if (i === 2) setListaCanales(CANALES_MANUALES);
        await new Promise(r => setTimeout(r, 800));
      }
    }
    setLoadingChannels(false);
    cargaEnCurso.current = false;
  }, []);

  useEffect(() => {
    cargarListaM3U();
  }, []);

  const onRefresh = useCallback(async () => {
    setRefreshing(true);
    await cargarListaM3U();
    setRefreshing(false);
  }, [cargarListaM3U]);

  // --- CARGA DE PELÍCULAS DRIVE ---
  const cargarDriveMovies = useCallback(async (force = false) => {
    if (force) driveMoviesLoaded.current = false;
    if (loadingDriveMovies || driveMoviesLoaded.current) return;
    setLoadingDriveMovies(true);
    try {
      const items = await cargarCarpetaDrive(DRIVE_FOLDER_PELICULAS, 'movie', 'driveMoviesCache');
      setDriveMovies(items);
      driveMoviesLoaded.current = true;
    } finally {
      setLoadingDriveMovies(false);
    }
  }, [loadingDriveMovies]);

// ===== CARGA DE SERIES (con caché persistente y fallback) =====
const cargarPlex = useCallback(async (force = false) => {
  // Evita múltiples cargas simultáneas
  if (loadingPlex) return;

  // Si no es forzado y ya se cargó en esta sesión, salir
  if (!force && plexLoaded.current) return;

  // Si no es forzado, intentar cargar desde caché
  if (!force) {
    try {
      const cached = await AsyncStorage.getItem('driveSeriesShowsCache');
      if (cached) {
        const shows = JSON.parse(cached);
        if (Array.isArray(shows) && shows.length > 0) {
          setPlexShows(shows);
          plexLoaded.current = true;
          console.log('[Series] Cargado desde caché:', shows.length, 'series');
          return;
        }
      }
    } catch (e) {
      console.warn('[Series] Error al leer caché:', e);
    }
  }

  // Si llegamos aquí, no hay caché válida o se fuerza la recarga
  setLoadingPlex(true);
  try {
    console.log('[Series] Escaneando Drive...');
    const shows = await cargarSeriesPlex(DRIVE_FOLDER_SERIES, 'driveSeriesCache');
    console.log('[Series] Drive devolvió:', shows.length, 'series');
    setPlexShows(shows);
    // Guardar en caché
    await AsyncStorage.setItem('driveSeriesShowsCache', JSON.stringify(shows));
    plexLoaded.current = true;
  } catch (error) {
    console.error('[Series] Error al cargar desde Drive:', error);
    // Si falla Drive, intentar recuperar caché aunque esté vacía o corrupta
    try {
      const cached = await AsyncStorage.getItem('driveSeriesShowsCache');
      if (cached) {
        const shows = JSON.parse(cached);
        if (Array.isArray(shows)) {
          setPlexShows(shows);
          plexLoaded.current = true;
          console.log('[Series] Recuperado caché de respaldo:', shows.length);
          return;
        }
      }
    } catch (e) {
      console.warn('[Series] No se pudo recuperar caché de respaldo');
    }
    // Si todo falla, dejar array vacío
    setPlexShows([]);
    plexLoaded.current = false; // para permitir reintentar
  } finally {
    setLoadingPlex(false);
  }
}, [loadingPlex]);



  // --- CAMBIO DE TAB CON ANIMACIÓN ---
  const tabOpacity = useRef(new Animated.Value(1)).current;
  const changeTab = (i: number) => {
    LayoutAnimation.configureNext(LayoutAnimation.Presets.easeInEaseOut);
    Animated.timing(tabOpacity, { toValue: 0, duration: 80, useNativeDriver: true }).start(() => {
      setActiveTab(i);
      Animated.timing(tabOpacity, { toValue: 1, duration: 80, useNativeDriver: true }).start();
    });
  };

  // --- MANEJO DE PERFILES ---
  const onSelectProfile = useCallback((id: string) => {
    setActiveProfileId(id);
    setProfileSelection(false);
  }, [setActiveProfileId]);

  const handleAddProfile = useCallback((name: string, color: string) => {
    addProfile(name, color);
  }, [addProfile]);

  const handleDeleteProfile = useCallback((id: string) => {
    deleteProfile(id);
  }, [deleteProfile]);

  const goToProfileSelection = () => setProfileSelection(true);

  // --- RENDERIZADO DE SPLASH ---
  if (splash) {
    const spin = ringRot.interpolate({ inputRange: [0, 1], outputRange: ['0deg', '360deg'] });
    const progressWidth = progressA.interpolate({ inputRange: [0, 1], outputRange: ['0%', '100%'] });
    return (
