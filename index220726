const TNT_INJECTION_AFTER = `(function() {
  function post(url) {
    try {
      if (typeof url !== 'string' || url.length < 12) return;
      if (!/(\\.m3u8|\\.mpd)(\\?|#|$)/i.test(url)) return;
      window.ReactNativeWebView.postMessage('FOUND_MANIFEST:' + url);
