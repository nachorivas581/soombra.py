function esTituloEpisodioValido(t: string): boolean { if (!t || t.length < 2) return false; const letras = t.replace(/[0-9\s]/g, ''); return letras.length >= 2; }

function parsePlexEpisode(nombre: string): { showName: string; season: number; episode: number; episodeTitle?: string } | null {
  // Limpiar nombre: quitar extensión y normalizar caracteres raros
  let clean = nombre.replace(/\.(mp4|mkv|avi|mov|webm|m4v)$/i, '');
  // Eliminar puntos suspensivos repetidos
  clean = clean.replace(/\.{2,}/g, '.');
  // Reemplazar puntos y guiones bajos por espacios, pero conservar los puntos de separación
  // Para patrones como "The.Silent.Sea.1x08" queremos que "The.Silent.Sea" sea el nombre
  // y "1x08" sea el episodio. Usaremos una estrategia: buscar el patrón de episodio al final.
  // Primero intentamos extraer el patrón "número x número" al final de la cadena.
  const epPattern = /(\d{1,2})[Xx](\d{1,3})/;
  const epMatch = clean.match(epPattern);
  if (!epMatch) {
    console.log('[PARSE] No se encontró patrón de episodio en:', clean);
    return null;
  }

  // Extraer temporada y episodio
  const season = parseInt(epMatch[1], 10);
  const episode = parseInt(epMatch[2], 10);

  // Ahora extraer el nombre de la serie: todo lo que está antes del patrón de episodio
  // Buscar la posición donde comienza el patrón de episodio en la cadena original limpia
  const epIndex = clean.search(epPattern);
  let showName = '';
  if (epIndex > 0) {
    // Hay texto antes del patrón, ese es el nombre de la serie
    showName = clean.substring(0, epIndex).trim();
    // Limpiar el nombre: reemplazar puntos, guiones bajos, etc.
    showName = showName.replace(/[._-]+/g, ' ').trim();
  } else {
    // No hay nombre, el archivo empieza directamente con el patrón
    showName = ''; // Se usará el nombre de la carpeta en el paso superior
  }

  // Si hay un título después del patrón (ej. "01x01 - Título"), intentar extraerlo
  let title = '';
  const afterEp = clean.substring(epIndex + epMatch[0].length).trim();
  if (afterEp) {
    // Si después del patrón hay algo, puede ser un título o basura (como ".mkv" ya quitado)
    // Quitamos separadores comunes y vemos si queda algo relevante
    let possibleTitle = afterEp.replace(/^[-–\s]+/, '').replace(/[-–\s]+$/, '');
    if (possibleTitle) {
      // Filtrar palabras comunes que no son título
      possibleTitle = possibleTitle.replace(/\b(1080p|720p|2160p|4k|hdr|web[-]?dl|bluray|brrip|hdtv|x264|x265|hevc|aac|dual|latino|castellano|subtitulado|proper|repack|internal|dubbed|subbed|español|ingles|cap(itulo)?s?|temporada)\b/gi, '')
        .replace(/\s{2,}/g, ' ').trim();
      if (possibleTitle && esTituloEpisodioValido(possibleTitle)) {
        title = possibleTitle;
      }
    }
  }

  console.log('[PARSE] Éxito:', { showName: showName || '(de carpeta)', season, episode, title: title || 'ninguno' });

  return {
    showName: showName, // puede ser vacío, luego se usará la carpeta
    season,
    episode,
    episodeTitle: title || undefined,
  };
}

function limpiarNombreArchivo(nombre: string): { titulo: string; anio?: number } {
  let n = nombre.replace(/\.(mp4|mkv|avi|mov|webm|m4v)$/i, '');
  const matchAnio = n.match(/\b(19|20)\d{2}\b/);
  const anio = matchAnio ? parseInt(matchAnio[0], 10) : undefined;
  n = n.replace(/[._]/g, ' ');
  // Eliminar patrones de episodio como 01x01, S01E01, etc.
  n = n.replace(/\b\d{1,2}[Xx]\d{1,3}\b/g, '');
  n = n.replace(/\b[Ss]\d{1,2}[Ee]\d{1,3}\b/g, '');
  n = n.replace(/\(.*?\)|\[.*?\]/g, ' ');
  n = n.replace(/\b(19|20)\d{2}\b/g, ' ');
  n = n.replace(/\b(1080p|720p|2160p|4k|hdr|web[-]?dl|bluray|brrip|hdtv|x264|x265|hevc|aac|dual|latino|castellano|subtitulado|temporada|cap(itulo)?s?|r480p|s\s?\d{1,2}|hd|full\s?hd|mic?rohd|proper|repack|internal|dubbed|subbed|español|ingles)\b/gi, ' ');
  n = n.replace(/\bS\d{1,2}(E\d{1,2})?\b/gi, ' ');
  n = n.replace(/\s{2,}/g, ' ').trim();
  return { titulo: n, anio };
}

