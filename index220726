  const canalAnterior = () => {
    const lista = listaCanales;
    if (!canal || !lista.length) return;
    const idx = lista.findIndex(c => c.id === canal.id);
    sintonizar(lista[idx === 0 ? lista.length - 1 : idx - 1]);
  };

  const onPlayerError = useCallback((errorMsg?: string) => {
    console.log('[LivePlayer] Error en reproductor:', errorMsg);
    setStreamError(errorMsg || 'Error en la reproducción');
    if (canalRef.current?.category === 'Deportes' && useWebViewPlayer) {
      console.log('[LivePlayer] Error en WebView player, no reintentar.');
      return;
    }
    if (canalRef.current && canalRef.current.sources && canalRef.current.sources.length > 1) {
      const nextIdx = (currentSourceIndex + 1) % canalRef.current.sources.length;
      if (nextIdx !== currentSourceIndex) {
        console.log('[LivePlayer] Cambiando a fuente', nextIdx);
        cambiarFuente(nextIdx);
        return;
      }
    }
    setPlayerErrorCount(prev => prev + 1);
    if ((canalRef.current?.needsWebView || canalRef.current?.embedSlug) && playerErrorCount < 2) {
      console.log('[LivePlayer] Reintentando extracción, intento', playerErrorCount + 1);
      onPlayerExpired();
      return;
    }
    if (IS_ANDROID_TV && !forceWebView && linkM3u8) {
      console.log('[LivePlayer] Forzando WebView en TV Box.');
      setForceWebView(true);
      setEmbedWebView(true);
      setLinkM3u8(null);
      setPlayerErrorCount(0);
      return;
    }
    setLinkM3u8(null);
    limpiarCaza();
    setPlayerErrorCount(0);
    if (canalRef.current?.needsWebView || canalRef.current?.embedSlug) {
      setUseEmbedPlayer(true);
    } else {
      setTimeout(() => { if (canalRef.current) sintonizar(canalRef.current); }, 500);
    }
  }, [forceWebView, linkM3u8, currentSourceIndex, playerErrorCount, useWebViewPlayer]);

  const onPlayerExpired = useCallback(async () => {
    const c = canalRef.current;
    if (!c || !c.embedSlug) return;
    console.log('[LivePlayer] Stream expirado, renovando...');

    const esDeportivo = c.category === 'Deportes' ||
      ['dsports', 'tycsports', 'espn', 'tntsports', 'clarosports', 'universal-premiere'].some(slug => c.embedSlug?.includes(slug));

    setEmbedBuscando(true);
    let newStream: string | null = null;

    if (esDeportivo) {
      newStream = await obtenerStreamDeportes(c.embedSlug, c.url);
      if (!newStream) {
        console.log('[LivePlayer] Falló extractor deportivo en renovación, usando WebView extractor...');
        streamFoundRef.current = false;
        const wvStream = await new Promise<string | null>((resolve) => {
          pendingResolve.current = resolve;
          setWebViewExtractor(c.url);
          setTimeout(() => {
            if (pendingResolve.current) {
              pendingResolve.current(null);
              pendingResolve.current = null;
              setWebViewExtractor(null);
            }
          }, 15000);
        });
        setWebViewExtractor(null);
        if (wvStream) newStream = wvStream;
      }
    } else {
      newStream = await obtenerStreamTNT(c.embedSlug, c.url, 0);
    }

    if (newStream) {
      console.log('[LivePlayer] Stream renovado exitosamente.');
      if (!c.sources) c.sources = [];
      if (!c.sources.includes(newStream) && c.sources.length < MAX_SOURCES) {
        c.sources.push(newStream);
      }
      // Forzar WebView si es gambeta
      if (newStream.includes('gambeta.vip') || newStream.includes('cdn.gambeta.vip')) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(newStream);
        setLinkM3u8(null);
      } else if (esDeportivo) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(newStream);
        setLinkM3u8(null);
      } else {
        setLinkM3u8(newStream);
      }
      setEmbedBuscando(false);
    } else {
      console.log('[LivePlayer] Falló la renovación. Reintentando en 5s...');
      setEmbedBuscando(false);
      setTimeout(() => {
        if (canalRef.current) onPlayerExpired();
      }, 5000);
    }
  }, []);

  const onMsgEmbed = async (e: WebViewMessageEvent) => {
    const data = String(e.nativeEvent.data || '').trim();
    console.log('[LivePlayer] Mensaje del WebView embed:', data);
    if (data.startsWith('FOUND_MANIFEST:')) {
      let rawUrl = data.replace('FOUND_MANIFEST:', '');
      if (!rawUrl || rawUrl.length < 20 || rawUrl.includes('...') || rawUrl.includes('undefined')) {
        console.warn('[LivePlayer] URL de manifiesto inválida o truncada:', rawUrl);
        return;
      }
      rawUrl = cacheBust(rawUrl);
      try {
        const res = await fetch(rawUrl, { method: 'HEAD', headers: { 'User-Agent': 'Mozilla/5.0', 'Referer': canalRef.current?.url || 'https://streamhdx.com/' } });
        if (!res.ok) {
          console.warn('[LivePlayer] El stream devuelve', res.status, 'para', rawUrl);
          if (res.status === 404 || res.status === 403) {
            setStreamError('Stream no disponible (404)');
            return;
          }
        }
      } catch (e) {
        console.warn('[LivePlayer] Error verificando stream:', e);
      }
      const mejorUrl = await seleccionarMejorCalidad(rawUrl);
      console.log('[LivePlayer] Manifest válido, usando mejor calidad:', mejorUrl);
      const c = canalRef.current;
      if (c) {
        if (!c.sources) c.sources = [];
        if (!c.sources.includes(mejorUrl) && c.sources.length < MAX_SOURCES) {
          c.sources.push(mejorUrl);
        }
      }
      // Forzar WebView si es gambeta
      if (mejorUrl.includes('gambeta.vip') || mejorUrl.includes('cdn.gambeta.vip')) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(mejorUrl);
      } else {
        setLinkM3u8(mejorUrl);
      }
      setEmbedBuscando(false);
      setEmbedWebView(false);
      setUseEmbedPlayer(false);
      limpiarCaza();
      return;
    }
    if (esUrlManifiesto(data)) {
      const mejorUrl = await seleccionarMejorCalidad(data);
      const c = canalRef.current;
      if (c) {
        if (!c.sources) c.sources = [];
        if (!c.sources.includes(mejorUrl) && c.sources.length < MAX_SOURCES) {
          c.sources.push(mejorUrl);
        }
      }
      if (mejorUrl.includes('gambeta.vip') || mejorUrl.includes('cdn.gambeta.vip')) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(mejorUrl);
      } else {
        setLinkM3u8(mejorUrl);
      }
      setEmbedBuscando(false);
      setEmbedWebView(false);
      setUseEmbedPlayer(false);
      limpiarCaza();
      return;
    }
    if (data === 'MANIFEST_TIMEOUT') {
      console.log('[LivePlayer] Timeout en extracción de embed.');
      setEmbedBuscando(false);
      setEmbedWebView(false);
      setUseEmbedPlayer(true);
      limpiarCaza();
      Alert.alert('Canal', 'No se pudo extraer el stream. Usando reproductor embed.');
    }
  };

  const onMsgWebView = (e: WebViewMessageEvent) => {
    const data = String(e.nativeEvent.data || '');
    console.log('[LivePlayer] Mensaje del WebView de extracción:', data);
    const m = extraerManifiesto(data);
    if (m) {
      const c = canalRef.current;
      if (c) {
        if (!c.sources) c.sources = [];
        if (!c.sources.includes(m) && c.sources.length < MAX_SOURCES) {
          c.sources.push(m);
        }
      }
      if (m.includes('gambeta.vip') || m.includes('cdn.gambeta.vip')) {
        setUseWebViewPlayer(true);
        setWebViewPlayerUrl(m);
      } else {
        setLinkM3u8(m);
      }
      setCazando(false);
      limpiarCaza();
    }
  };

  // ========== SINTONIZAR ==========
  const sintonizar = async (c: Canal, attempt = 0) => {
    console.log(`[LivePlayer] sintonizar() llamada para: ${c.name} (${c.id})`);
    console.log(`[LivePlayer] URL: ${c.url}`);
    console.log(`[LivePlayer] embedSlug: ${c.embedSlug}`);
    console.log(`[LivePlayer] needsWebView: ${c.needsWebView}`);

    const MAX_ATTEMPTS = 3;

    limpiarCaza();
    setLinkM3u8(null);
    setCanal(c);
    setEmbedBuscando(false);
    setEmbedWebView(false);
    setCazando(false);
    setForceWebView(false);
    setUseEmbedPlayer(false);
    setUseWebViewPlayer(false);
    setWebViewPlayerUrl(null);
    setCurrentSourceIndex(0);
    setStreamError(null);
    setRecents((prev) => [c, ...prev.filter((x) => x.id !== c.id)].slice(0, 8));
    Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light);

    if (!c.sources || c.sources.length === 0) {
      let newSources: string[] = [];
      if (c.url && !newSources.includes(c.url)) {
        newSources.push(c.url);
      }
      const slug = c.embedSlug || extractEmbedSlug(c.url) || '';
      if (slug) {
        const altUrls = generarUrlsAlternativas(slug);
        for (const url of altUrls) {
          newSources = agregarFuenteConLimite(newSources, url);
        }
      }
      c.sources = newSources;
    }
    console.log(`[LivePlayer] Fuentes iniciales: ${c.sources.length}`);

    const esDeportivo = c.category === 'Deportes' ||
      ['dsports', 'tycsports', 'espn', 'tntsports', 'clarosports', 'universal-premiere'].some(s => c.embedSlug?.includes(s));

    // CASO 1: Canal con embedSlug
    if (c.embedSlug || c.needsWebView) {
      console.log('[LivePlayer] Caso embedSlug/needsWebView');
      const slug = c.embedSlug || extractEmbedSlug(c.url) || '';
      setEmbedBuscando(true);

      let stream: string | null = null;

      if (esDeportivo) {
        console.log('[LivePlayer] Usando extractor deportivo para:', slug);
        stream = await obtenerStreamDeportes(slug, c.url);
        if (!stream) {
