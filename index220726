const GlobalSearch = memo(({ visible, onClose, primaryColor, listaCanales, driveMovies, plexShows, onSelectChannel }: {
  visible: boolean; onClose: () => void; primaryColor: string;
  listaCanales: Canal[]; driveMovies: MediaItem[]; plexShows: PlexShow[];
  onSelectChannel?: (channel: Canal) => void;
}) => {
  const [query, setQuery] = useState('');
  const [results, setResults] = useState<SearchResult[]>([]);
  const [loading, setLoading] = useState(false);

  useEffect(() => { setQuery(''); setResults([]); }, [visible]);

  const performSearch = useCallback(async (text: string) => {
    if (text.length < 2) { setResults([]); return; }
    setLoading(true);
    const q = text.toLowerCase();
    const combined: SearchResult[] = [];

    listaCanales.filter(c => c.name.toLowerCase().includes(q)).forEach(c => {
      combined.push({ id: c.id, title: c.name, poster: c.logo, type: 'channel', source: c });
    });
    driveMovies.filter(m => m.title.toLowerCase().includes(q)).forEach(m => {
      combined.push({ id: m.id, title: m.title, poster: m.poster, type: 'movie', source: m });
    });
    plexShows.filter(sv => sv.title.toLowerCase().includes(q)).forEach(sv => {
      combined.push({ id: sv.id, title: sv.title, poster: sv.poster, type: 'tv', source: sv });
    });

    try {
      const res = await fetch(`https://api.themoviedb.org/3/search/movie?api_key=${TMDB_API_KEY}&language=es&query=${encodeURIComponent(q)}`);
      const data = await res.json();
      (data.results || []).slice(0,5).forEach((m:any) => {
        combined.push({ id:`tmdb_m_${m.id}`, title:m.title, poster:`https://image.tmdb.org/t/p/w500${m.poster_path}`, type:'tmdb_movie', source:m });
      });
    } catch {}
    try {
      const res = await fetch(`https://api.themoviedb.org/3/search/tv?api_key=${TMDB_API_KEY}&language=es&query=${encodeURIComponent(q)}`);
      const data = await res.json();
      (data.results || []).slice(0,5).forEach((sv:any) => {
        combined.push({ id:`tmdb_t_${sv.id}`, title:sv.name, poster:`https://image.tmdb.org/t/p/w500${sv.poster_path}`, type:'tmdb_tv', source:sv });
      });
    } catch {}
    setResults(combined);
    setLoading(false);
  }, [listaCanales, driveMovies, plexShows]);

  useEffect(() => {
    const timer = setTimeout(() => performSearch(query), 300);
    return () => clearTimeout(timer);
  }, [query]);

  const typeLabel: Record<string, string> = {
    channel: 'Canal',
    movie: 'Película',
    tv: 'Serie',
    tmdb_movie: 'TMDB · Película',
    tmdb_tv: 'TMDB · Serie'
  };

  const renderItem = ({ item }: { item: SearchResult }) => (
    <TouchableOpacity
      style={gs.resultRow}
      onPress={() => {
        if (item.type === 'channel' && onSelectChannel && item.source) {
          onSelectChannel(item.source);
          onClose();
          return;
        }
        Alert.alert(`Ir a ${item.title}`);
        onClose();
      }}
    >
      <Image source={{ uri: item.poster || 'https://via.placeholder.com/50' }} style={gs.resultPoster} />
      <View style={{ flex: 1 }}>
        <Text style={gs.resultTitle} numberOfLines={1}>{item.title}</Text>
        <Text style={gs.resultSub}>{typeLabel[item.type] ?? item.type}</Text>
      </View>
      <Ionicons name="chevron-forward" size={16} color={T.color.inkFaint} />
    </TouchableOpacity>
  );

  return (
    <Modal visible={visible} animationType="slide" transparent={false}>
      <View style={gs.container}>
        <View style={gs.header}>
          <View style={gs.inputWrap}>
            <Ionicons name="search" size={17} color={T.color.inkFaint} style={{ marginRight: 8 }} />
            <TextInput style={gs.input} placeholder="Buscar en toda la app…" placeholderTextColor={T.color.inkFaint} value={query} onChangeText={setQuery} autoFocus />
            {query.length > 0 && <TouchableOpacity onPress={() => setQuery('')}><Ionicons name="close-circle" size={17} color={T.color.inkFaint} /></TouchableOpacity>}
          </View>
          <TouchableOpacity style={gs.closeBtn} onPress={onClose}><Text style={[gs.closeTxt, { color: primaryColor }]}>Cancelar</Text></TouchableOpacity>
        </View>
        {loading ? (
          <View style={{ flex: 1, alignItems: 'center', justifyContent: 'center' }}><ActivityIndicator color={primaryColor} /></View>
        ) : results.length === 0 && query.length >= 2 ? (
          <View style={{ flex: 1, alignItems: 'center', justifyContent: 'center' }}>
            <Ionicons name="search-outline" size={48} color={T.color.inkFaint} />
            <Text style={{ color: T.color.inkFaint, marginTop: 12, fontSize: T.font.base }}>Sin resultados para "{query}"</Text>
          </View>
        ) : (
          <FlatList data={results} keyExtractor={item => item.id} renderItem={renderItem} keyboardShouldPersistTaps="handled" contentContainerStyle={{ paddingHorizontal: T.color.inkFaint, paddingTop: T.space.sm }} />
        )}
      </View>
    </Modal>
  );
});


