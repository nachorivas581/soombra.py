async function obtenerStreamDeportes(
  embedSlug: string,
  urlBase?: string,
  retryCount = 0
): Promise<string | null> {
  const MAX_RETRIES = 3;
  const delay = (ms: number) => new Promise(r => setTimeout(r, ms));

  const vertvcableSlugs: Record<string, string> = {
    'universalpremiere': 'universal-premiere-en-vivo',
  };

  const posiblesUrls: string[] = [];

  if (urlBase) {
    posiblesUrls.push(urlBase);
  } else {
    posiblesUrls.push(
      `https://streamhdx.com/live1.php?stream=${embedSlug}`,
      `https://streamhdx.com/live1.php?stream=${embedSlug}&hd=1`,
      `https://streamhdx.com/live1.php?stream=${embedSlug}&type=2`,
      `https://gambeta.vip/canal/${embedSlug}`,
      `https://embed.saohgdasregions.fun/embed2/${embedSlug}.php`,
      `https://librepelota.su/es/${embedSlug}/`
    );

    if (vertvcableSlugs[embedSlug]) {
      posiblesUrls.push(
        `https://www.vertvcable.com/${vertvcableSlugs[embedSlug]}/`
      );
    }
  }

  const urlsToTry = [...new Set(posiblesUrls)].filter(u => u && u.length > 0);

  for (let intento = 0; intento <= retryCount; intento++) {
    for (const url of urlsToTry) {
      try {
        console.log(`[Deportes] Intentando: ${url}`);
        const res = await fetch(url, {
          headers: {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
            'Referer': url.includes('gambeta.vip') ? 'https://gambeta.vip/' : 'https://streamhdx.com/',
            'Origin': url.includes('gambeta.vip') ? 'https://gambeta.vip' : 'https://streamhdx.com',
            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
          },
        });
        const html = await res.text();

        // ============================================================
        // ESTRATEGIA ESPECÍFICA PARA gambeta.vip (CON MAPEO MANUAL)
        // ============================================================
        if (url.includes('gambeta.vip')) {
          const manualRefKind: Record<string, { ref: string; kind: string }> = {
            'universal-premiere': { ref: '126', kind: 'xt' },
            'universalpremiere': { ref: '126', kind: 'xt' },
            // Agrega más si encuentras otros
          };

          const gambetaSlug = url.match(/\/canal\/([^\/]+)/)?.[1] || embedSlug;

          let refMatch = html.match(/REF\s*=\s*["']([^"']+)["']/);
          let kindMatch = html.match(/KIND\s*=\s*["']([^"']+)["']/);
          let ref = refMatch ? refMatch[1] : null;
          let kind = kindMatch ? kindMatch[1] : null;

          if (!ref || !kind) {
            const manual = manualRefKind[gambetaSlug] || manualRefKind[embedSlug];
            if (manual) {
              ref = manual.ref;
              kind = manual.kind;
              console.log(`[Deportes] Usando mapeo manual para ${gambetaSlug}: REF=${ref}, KIND=${kind}`);
            }
          }

          if (ref && kind) {
            console.log(`[Deportes] gambeta.vip -> REF=${ref}, KIND=${kind}`);
            try {
              const keyRes = await fetch('https://gambeta.vip/api/k.php', {
                headers: {
                  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
                  'Referer': url,
                  'Origin': 'https://gambeta.vip',
                },
              });
              const key = (await keyRes.text()).trim();
              if (key) {
                const streamType = kind === 'xt' ? 'xt' : 'tv';
                const streamUrl = `https://cdn.gambeta.vip/${streamType}/${ref}.m3u8?k=${encodeURIComponent(key)}`;
                console.log(`[Deportes] Stream desde gambeta.vip: ${streamUrl}`);
                return streamUrl;
              } else {
                console.warn('[Deportes] Clave vacía desde gambeta.vip/api/k.php');
              }
            } catch (e) {
              console.warn('[Deportes] Error al obtener clave de gambeta.vip:', e);
            }
          } else {
            console.warn('[Deportes] No se encontraron REF/KIND en gambeta.vip');
          }
        }

        // ============================================================
        // ESTRATEGIAS GENERALES (Clappr, playbackURL, source, m3u8 directo)
        // ============================================================
        const scriptRegex = /<script[^>]*>([\s\S]*?)<\/script>/gi;
        let scriptMatch;
        let allScripts = '';
        while ((scriptMatch = scriptRegex.exec(html)) !== null) {
          allScripts += scriptMatch[1] + '\n';
        }

        // nZ + vyWzk + tDqCX (Clappr)
        const nzRegex = /nZ\s*=\s*(\[\[[\s\S]*?\]\])\s*;/;
        const nzMatch = allScripts.match(nzRegex);
        if (nzMatch) {
          const nzContent = nzMatch[1];
          const pairRegex = /\[(\d+)\s*,\s*"([^"]+)"\]/g;
          const pairs = [];
          let pairMatch;
          while ((pairMatch = pairRegex.exec(nzContent)) !== null) {
            pairs.push([parseInt(pairMatch[1], 10), pairMatch[2]]);
          }
          if (pairs.length > 0) {
            pairs.sort((a, b) => a[0] - b[0]);
            const vyWzkMatch = allScripts.match(/function\s+vyWzk\s*\(\s*\)\s*\{\s*return\s*(\d+);/);
            const tDqCXMatch = allScripts.match(/function\s+tDqCX\s*\(\s*\)\s*\{\s*return\s*(\d+);/);
            if (vyWzkMatch && tDqCXMatch) {
              const k = parseInt(vyWzkMatch[1], 10) + parseInt(tDqCXMatch[1], 10);
              let decoded = '';
              for (const [, base64] of pairs) {
                try {
                  const str = atob(base64);
                  const num = parseInt(str.replace(/\D/g, ''), 10);
                  const charCode = num - k;
                  decoded += String.fromCharCode(charCode);
                } catch (_) {}
              }
              if (decoded && decoded.startsWith('http')) {
                const normalized = normalizarUrl(decoded);
                console.log(`[Deportes] Stream decodificado (Clappr): ${normalized}`);
                return normalized;
              }
            }
          }
        }

        // playbackURL
        const playbackMatch = allScripts.match(/playbackURL\s*=\s*["']([^"']+)["']/);
        if (playbackMatch && playbackMatch[1]) {
          const normalized = normalizarUrl(playbackMatch[1]);
          console.log(`[Deportes] Stream encontrado (playbackURL): ${normalized}`);
          return normalized;
        }

        // source en Clappr
        const sourceMatch = allScripts.match(/source\s*:\s*["']([^"']+)["']/);
        if (sourceMatch && sourceMatch[1]) {
          const normalized = normalizarUrl(sourceMatch[1]);
          console.log(`[Deportes] Stream encontrado (source): ${normalized}`);
          return normalized;
        }

        // m3u8 directo en el HTML
        const m3u8Match = html.match(/(?:https?:)?\/{1,2}[^\s"'<>]+\.m3u8[^\s"'<>]*/i);
        if (m3u8Match) {
          const normalized = normalizarUrl(m3u8Match[0]);
          console.log(`[Deportes] Stream encontrado (m3u8 directo): ${normalized}`);
          return normalized;
        }
      } catch (e) {
        console.warn(`[Deportes] Error en ${url}:`, e);
      }
    }
    await delay(1000 * (intento + 1));
  }

  console.log(`[Deportes] No se encontró stream en ningún dominio para ${embedSlug}`);
  return null;
}

