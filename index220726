// ---------- Helper: normalizar URL ----------
function normalizarUrl(url: string): string {
  let u = url.trim().replace(/\\\//g, '/');
  if (u.startsWith('//')) u = 'https:' + u;
  if (!/^https?:\/\//i.test(u)) u = 'https://' + u;
  u = u.replace(/[^a-zA-Z0-9\-._~:/?#\[\]@!$&'()*+,;=%]+$/, '');
  return u;
}

