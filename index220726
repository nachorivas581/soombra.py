/* ─────────────────────────────────────────────
   REPRODUCTOR NATIVO CON TIMEOUT Y MANEJO DE ERRORES
───────────────────────────────────────────── */
export type ReproductorNativoHandle = {
  seekBy: (secs: number) => void;
  setVolume: (vol: number) => void;
  togglePlay: () => void;
};

const ReproductorNativo = memo(forwardRef<
  ReproductorNativoHandle,
  {
    url: string;
    contentFit: 'contain' | 'fill';
    isLive?: boolean;
    onError?: (errorMsg?: string) => void;
    onStall?: () => void;
    showSeekControls?: boolean;
    onProgressUpdate?: (current: number, duration: number) => void;
    itemInfo?: ContinueWatchingItem;
    onPlayStateChange?: (isPlaying: boolean) => void;
    onExpired?: () => void;
    useWebViewFallback?: boolean; // 🔥 NUEVO: forzar WebView
  }
>(
  (
    {
      url,
      contentFit,
      isLive = false,
      onError,
      onStall,
      showSeekControls = false,
      onProgressUpdate,
      itemInfo,
      onPlayStateChange,
      onExpired,
      useWebViewFallback = false,
    },
    ref
  ) => {
    useKeepAwake();
    const [activeUrl, setActiveUrl] = useState(() => isLive ? cacheBust(url) : url);
    const [fallbackWebView, setFallbackWebView] = useState(useWebViewFallback);
    const [webViewUrl, setWebViewUrl] = useState<string | null>(useWebViewFallback ? url : null);
    const webViewRef = useRef<WebView>(null);
    const [errorMessage, setErrorMessage] = useState<string | null>(null);
    const stallTimeout = useRef<ReturnType<typeof setTimeout> | null>(null);

    // Reproductor nativo (solo si no usamos WebView)
    const player = useVideoPlayer(activeUrl, (p) => {
      p.loop = false;
      if (isLive) try { (p as any).seekToLiveEdge?.(); } catch (_) {}
      if (Platform.OS === 'android') {
        try {
          (p as any).setAllowsExternalPlayback?.(true);
          (p as any).setPictureInPicture?.(true);
          (p as any).setMinimumLoadableRetryCount?.(10);
          (p as any).setBufferTimeout?.(60000);
          (p as any).setMaxBufferSize?.(1024 * 1024 * 60);
          (p as any).setPreload?.(true);
          (p as any).setPlayWhenReady?.(true);
        } catch (_) {}
      }
      if (IS_ANDROID_TV) {
        try {
          (p as any).setBufferTimeout?.(90000);
          (p as any).setMaxBufferSize?.(1024 * 1024 * 80);
        } catch (_) {}
      }
      p.play();
    });

    const seekBy = useCallback(
      (secs: number) => {
        try { player.currentTime = Math.max(0, (player.currentTime ?? 0) + secs); } catch (_) {}
      },
      [player]
    );
    const setVolume = useCallback(
      (vol: number) => {
        try { player.volume = vol; } catch (_) {}
      },
      [player]
    );
    const togglePlay = useCallback(() => {
      try {
        if (player.playing) {
          player.pause();
          onPlayStateChange?.(false);
        } else {
          player.play();
          onPlayStateChange?.(true);
        }
      } catch (_) {}
    }, [player, onPlayStateChange]);

    useImperativeHandle(
      ref,
      () => ({ seekBy, setVolume, togglePlay }),
      [seekBy, setVolume, togglePlay]
    );

    const handleError = useCallback((error?: any) => {
  let msg = 'Error al reproducir';
  if (error) {
    // Si es un objeto con message, usamos ese
    const errMsg = error.message || String(error);
    const errStr = String(errMsg).toLowerCase();
    if (errStr.includes('404')) msg = 'Stream no disponible (404)';
    else if (errStr.includes('403')) msg = 'Acceso denegado (403)';
    else if (errStr.includes('network')) msg = 'Error de red, verifica tu conexión';
    else if (errStr.includes('source')) msg = 'El stream no es válido o ha expirado';
    else if (errStr.includes('playback')) msg = 'Error de reproducción';
  }
  setErrorMessage(msg);
  onError?.(msg);
  // ...
}, [useWebViewFallback, url, onError, onExpired]);
    // Fallback WebView (hls.js) con Referer para gambeta
    if (fallbackWebView && webViewUrl) {
      const isGambeta = webViewUrl.includes('gambeta.vip') || webViewUrl.includes('cdn.gambeta.vip');
      const html = `
        <!DOCTYPE html>
        <html>
        <head>
          <meta charset="UTF-8">
          <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
          <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
          <style>
            body { margin: 0; background: #000; }
            video { width: 100vw; height: 100vh; object-fit: contain; background: #000; }
          </style>
        </head>
        <body>
          <video id="video" controls autoplay playsinline></video>
          <script>
            var video = document.getElementById('video');
            var streamUrl = '${webViewUrl}';
            var isGambeta = ${isGambeta};
            if (Hls.isSupported()) {
              var hls = new Hls({
                enableWorker: false,
                maxBufferLength: 30,
                xhrSetup: function(xhr, url) {
                  if (isGambeta) {
                    xhr.setRequestHeader('Referer', 'https://gambeta.vip/');
                    xhr.setRequestHeader('Origin', 'https://gambeta.vip');
                    xhr.setRequestHeader('User-Agent', 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36');
                  }
                }
              });
              hls.loadSource(streamUrl);
              hls.attachMedia(video);
              hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play(); });
              hls.on(Hls.Events.ERROR, function(e, d) {
                if (d.fatal) window.ReactNativeWebView.postMessage('HLS_ERROR:' + d.type);
              });
            } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
              video.src = streamUrl;
              video.addEventListener('loadedmetadata', function() { video.play(); });
            } else {
              document.body.innerHTML = '<p style="color:white;text-align:center;margin-top:40%;">Reproductor no compatible</p>';
            }
            // Monitoreo para evitar que se trabe
            var lastTime = 0;
            var stuckCount = 0;
            setInterval(function() {
              if (video.currentTime === lastTime) {
                stuckCount++;
                if (stuckCount > 10) {
                  window.location.reload();
                }
              } else {
                stuckCount = 0;
                lastTime = video.currentTime;
              }
            }, 3000);
          </script>
        </body>
        </html>
      `;
      return (
        <WebView
          ref={webViewRef}
          source={{ html }}
          originWhitelist={['*']}
          javaScriptEnabled
          domStorageEnabled
          mediaPlaybackRequiresUserAction={false}
          allowsInlineMediaPlayback
          mixedContentMode="always"
          style={StyleSheet.absoluteFill}
          onMessage={(e) => {
            const data = e.nativeEvent.data;
            if (data && data.startsWith('HLS_ERROR:')) {
              handleError('Error en WebView: ' + data);
            }
          }}
        />
      );
    }

    // Status y playing change (solo para reproductor nativo)
    useEffect(() => {
      if (!player) return;
      const s1 = player.addListener('statusChange', (p: any) => {
        if (p?.error) {
          console.error('Error reproductor nativo:', p.error);
          handleError(p.error);
          return;
        }
        if ((p?.status ?? p) === 'idle') {
          try {
            player.replace(isLive ? cacheBust(url) : url);
            setTimeout(() => { try { player.play(); } catch (_) {} }, 400);
          } catch (_) {}
        }
      });
      const s2 = player.addListener('playingChange', (p: any) => {
        const playing = p?.isPlaying ?? p;
        onPlayStateChange?.(!!playing);
        if (!playing) {
          setTimeout(() => {
            try { if (!player.playing) player.play(); } catch (_) {}
          }, 6000);
        }
      });
      return () => {
        s1.remove();
        s2.remove();
      };
    }, [player, url, handleError, onExpired, onPlayStateChange, isLive]);

    // Progreso
    useEffect(() => {
      if (!player || !onProgressUpdate) return;
      const iv = setInterval(() => {
        try {
          onProgressUpdate(player.currentTime ?? 0, (player as any).duration ?? 0);
        } catch (_) {}
      }, 500);
      return () => clearInterval(iv);
    }, [player, onProgressUpdate]);

    return (
      <View style={StyleSheet.absoluteFill}>
        <VideoView
          style={StyleSheet.absoluteFill}
          player={player}
          contentFit={contentFit}
          nativeControls={false}
        />
        {errorMessage && (
          <View style={pl.errorOverlay}>
            <Ionicons name="alert-circle-outline" size={48} color="#fff" />
            <Text style={pl.errorText}>{errorMessage}</Text>
          </View>
        )}
        {showSeekControls && !errorMessage && (
          <View style={pl.seekOverlay} pointerEvents="box-none">
            <TouchableOpacity style={pl.seekBtn} onPress={() => seekBy(-10)}>
              <Ionicons name="play-back" size={22} color="#fff" />
              <Text style={pl.seekLabel}>10</Text>
            </TouchableOpacity>
            <TouchableOpacity style={pl.seekBtnPlay} onPress={togglePlay}>
              <Ionicons name="play" size={28} color="#fff" />
            </TouchableOpacity>
            <TouchableOpacity style={pl.seekBtn} onPress={() => seekBy(10)}>
              <Ionicons name="play-forward" size={22} color="#fff" />
              <Text style={pl.seekLabel}>10</Text>
            </TouchableOpacity>
          </View>
        )}
      </View>
    );
  }
));


/* ============================================================
   FULLSCREEN PLAYER (con overlay de error y selector de fuentes)
   ============================================================ */
interface FullscreenPlayerProps {
  url: string;
  isLive?: boolean;
  title?: string;
  subtitle?: string;
  onClose: () => void;
  primaryColor: string;
  onNext?: () => void;
  onPrev?: () => void;
  onError?: (errorMsg?: string) => void;
  itemInfo?: ContinueWatchingItem;
  onProgress?: (cur: number, dur: number) => void;
  onPlayStateChange?: (playing: boolean) => void;
  canales?: Canal[];
  canalActual?: Canal | null;
  onSelectCanal?: (canal: Canal) => void;
  favorites?: string[];
  toggleFavorito?: (id: string) => void;
  sources?: string[];
  currentSourceIndex?: number;
  onSourceChange?: (index: number) => void;
  loading?: boolean; // NUEVA PROP
}

const FullscreenPlayer = memo(({
  url,
  isLive = false,
  title,
  subtitle,
  onClose,
  primaryColor,
  onNext,
  onPrev,
  onError,
  itemInfo,
  onProgress,
  onPlayStateChange,
  canales,
  canalActual,
  onSelectCanal,
  favorites,
  toggleFavorito,
  sources,
  currentSourceIndex,
  onSourceChange,
  loading = false,
}: FullscreenPlayerProps) => {
  const [controlsVisible, setControlsVisible] = useState(true);
  const [aspect, setAspect] = useState<'contain' | 'fill'>('contain');
  const [currentTime, setCurrentTime] = useState(0);
  const [duration, setDuration] = useState(0);
  const [isPlaying, setIsPlaying] = useState(true);
  const [isLoading, setIsLoading] = useState(true);
  const [errorMessage, setErrorMessage] = useState<string | null>(null);
  const [showSourceSelector, setShowSourceSelector] = useState(false);

  const controlsAnim = useRef(new Animated.Value(1)).current;
  const hideTimer = useRef<ReturnType<typeof setTimeout> | null>(null);
  const playerRef = useRef<ReproductorNativoHandle>(null);
  const [brightnessVal, setBrightnessVal] = useState(0.5);
  const [volumeVal, setVolumeVal] = useState(0.5);
  const [showBrightness, setShowBrightness] = useState(false);
  const panType = useRef<'brightness' | 'volume' | null>(null);
  const seekBarRef = useRef<View>(null);
  const seekBarWidth = useRef(0);

  const [showSidebar, setShowSidebar] = useState(false);
  const sidebarAnim = useRef(new Animated.Value(W)).current;
  const panelWidth = Math.min(W * 0.65, 340);

  useEffect(() => {
    Animated.spring(sidebarAnim, {
      toValue: showSidebar ? 0 : panelWidth,
      useNativeDriver: true,
      tension: 65,
      friction: 11,
    }).start();
  }, [showSidebar]);

  const panResponder = useRef(PanResponder.create({
    onStartShouldSetPanResponder: () => true,
    onPanResponderGrant: (evt) => { const locX = evt.nativeEvent.locationX; panType.current = locX < W / 2 ? 'brightness' : 'volume'; },
    onPanResponderMove: async (evt, gestureState) => {
      if (!panType.current) return;
      const deltaY = (-gestureState.dy) / H * 0.8;
      if (panType.current === 'brightness') {
        const newBright = Math.max(0, Math.min(1, brightnessVal + deltaY));
        setBrightnessVal(newBright);
        Brightness.setBrightnessAsync(newBright);
        setShowBrightness(true);
      } else {
        const newVol = Math.max(0, Math.min(1, volumeVal + deltaY));
        setVolumeVal(newVol);
        playerRef.current?.setVolume(newVol);
        setShowBrightness(true);
      }
    },
    onPanResponderRelease: () => { panType.current = null; setTimeout(() => setShowBrightness(false), 800); },
  })).current;

  const seekPanResponder = useRef(PanResponder.create({
    onStartShouldSetPanResponder: () => true,
    onMoveShouldSetPanResponder: () => true,
    onPanResponderGrant: (evt) => handleSeekBarTouch(evt.nativeEvent.locationX),
    onPanResponderMove: (evt) => handleSeekBarTouch(evt.nativeEvent.locationX),
  })).current;

  useEffect(() => { lockLandscape(); return () => { lockPortrait(); }; }, []);

  const showControls = () => {
    setControlsVisible(true);
    Animated.timing(controlsAnim, { toValue: 1, duration: IS_ANDROID_TV ? 100 : 200, useNativeDriver: true }).start();
    resetHideTimer();
  };
  const resetHideTimer = () => {
    if (hideTimer.current) clearTimeout(hideTimer.current);
    hideTimer.current = setTimeout(() => {
      Animated.timing(controlsAnim, { toValue: 0, duration: IS_ANDROID_TV ? 200 : 400, useNativeDriver: true }).start(() => setControlsVisible(false));
    }, IS_ANDROID_TV ? 5000 : 3500);
  };
  useEffect(() => { resetHideTimer(); return () => { if (hideTimer.current) clearTimeout(hideTimer.current); }; }, []);

  const handleError = useCallback((errorMsg?: string) => {
    console.log('[FullscreenPlayer] Error recibido:', errorMsg);
    const is404 = errorMsg && (errorMsg.includes('404') || errorMsg.includes('no disponible') || errorMsg.includes('expirado'));
    
    if (is404) {
      // Si hay más fuentes, cambiar automáticamente a la siguiente
      if (sources && sources.length > 1 && currentSourceIndex !== undefined && currentSourceIndex + 1 < sources.length) {
        onSourceChange?.(currentSourceIndex + 1);
        setErrorMessage(null);
        setIsLoading(true);
        onError?.(errorMsg);
        return;
      }
      setErrorMessage('Stream no disponible (404)');
    } else if (errorMsg) {
      setErrorMessage(errorMsg);
    } else {
      setErrorMessage('Error al reproducir el stream');
    }
    
    setIsLoading(false);
    onError?.(errorMsg);
  }, [onError, sources, currentSourceIndex, onSourceChange]);

  const handlePlayStateChange = useCallback((playing: boolean) => {
    if (playing) setIsLoading(false);
    setIsPlaying(playing);
    onPlayStateChange?.(playing);
  }, [onPlayStateChange]);

  const handleProgress = useCallback((cur: number, dur: number) => {
    setCurrentTime(cur); setDuration(dur);
    if (dur > 0 && !isPlaying) setIsPlaying(true);
    onProgress?.(cur, dur);
    if (itemInfo && dur > 0) {
      saveContinueWatching({ ...itemInfo, progress: cur, duration: dur, watchedAt: Date.now() }, itemInfo.profileId || 'default');
    }
  }, [itemInfo, isPlaying, onProgress]);

  const handleSeekTo = useCallback((time: number) => {
    try { const diff = time - currentTime; playerRef.current?.seekBy(diff); } catch (_) {}
  }, [currentTime]);

  const handleSeekBarTouch = useCallback((locX: number) => {
    if (!seekBarWidth.current || duration <= 0) return;
    const fraction = Math.max(0, Math.min(1, locX / seekBarWidth.current));
    handleSeekTo(fraction * duration);
  }, [duration, handleSeekTo]);

  const progress = duration > 0 ? currentTime / duration : 0;

  // ============================================================
  // PANTALLA DE CARGA (cuando loading o url vacía)
  // ============================================================
  if (loading || !url) {
    return (
      <Modal visible animationType="fade" statusBarTranslucent>
        <View style={[fs.root, { justifyContent: 'center', alignItems: 'center', backgroundColor: T.color.bg }]}>
          <ActivityIndicator size="large" color={primaryColor} />
          <Text style={{ color: T.color.inkMid, marginTop: 16, fontSize: T.font.sm }}>
            {loading ? 'Cargando fuente...' : 'Conectando...'}
          </Text>
        </View>
      </Modal>
    );
  }

  // ============================================================
  // PANTALLA DE ERROR
  // ============================================================
  if (errorMessage) {
    return (
      <Modal visible animationType="fade" statusBarTranslucent>
        <View style={[fs.root, { justifyContent: 'center', alignItems: 'center', backgroundColor: T.color.bg }]}>
          <Ionicons name="alert-circle-outline" size={64} color="#ff6b6b" />
          <Text style={[fs.errorTitle, { color: '#fff', fontSize: T.font.xl, fontWeight: '700', marginTop: 20 }]}>
            {errorMessage}
          </Text>
          <Text style={[fs.errorSub, { color: T.color.inkMid, fontSize: T.font.sm, marginTop: 8, textAlign: 'center' }]}>
            El stream no está disponible en este momento. Puedes intentar con otra fuente.
          </Text>
          <View style={{ flexDirection: 'row', gap: T.space.md, marginTop: 30 }}>
            <TouchableOpacity
              style={[fs.closeBtn, { backgroundColor: primaryColor, paddingHorizontal: 24, paddingVertical: 12, borderRadius: T.radius.md }]}
              onPress={onClose}
            >
              <Text style={{ color: '#fff', fontWeight: '700' }}>Cerrar</Text>
            </TouchableOpacity>
            {sources && sources.length > 1 && (
              <TouchableOpacity
                style={[fs.closeBtn, { backgroundColor: T.color.surfaceHigh, paddingHorizontal: 24, paddingVertical: 12, borderRadius: T.radius.md, borderWidth: 1, borderColor: T.color.borderMid }]}
                onPress={() => {
                  const nextIdx = (currentSourceIndex !== undefined ? currentSourceIndex : 0) + 1;
                  if (nextIdx < sources.length) {
                    onSourceChange?.(nextIdx);
                    setErrorMessage(null);
                    setIsLoading(true);
                  }
                }}
              >
                <Text style={{ color: '#fff', fontWeight: '700' }}>Siguiente fuente</Text>
              </TouchableOpacity>
            )}
          </View>
        </View>
      </Modal>
    );
  }

  // ============================================================
  // RENDER PRINCIPAL
  // ============================================================
  return (
    <Modal visible animationType="fade" statusBarTranslucent supportRequestedOrientations={['landscape']}>
      <View style={fs.root} {...panResponder.panHandlers}>
        <StatusBar hidden />
        <TouchableWithoutFeedback onPress={showControls}>
          <View style={StyleSheet.absoluteFill}>
            {isLoading && (
              <View style={fs.loadingOverlay}>
                <ActivityIndicator size="large" color={primaryColor} />
                <Text style={fs.loadingText}>Cargando stream…</Text>
              </View>
            )}
            <ReproductorNativo
              ref={playerRef}
              url={url}
              contentFit={aspect}
              isLive={isLive}
              showSeekControls={false}
              onError={handleError}
              onProgressUpdate={handleProgress}
              itemInfo={itemInfo}
              onPlayStateChange={handlePlayStateChange}
              onExpired={() => handleError('El stream ha expirado')}
            />
          </View>
        </TouchableWithoutFeedback>

        {showBrightness && (
          <View style={fs.brightnessOverlay}>
            <Ionicons name={panType.current === 'brightness' ? 'sunny' : 'volume-high'} size={36} color="#fff" />
            <Text style={fs.brightnessValue}>{Math.round((panType.current === 'brightness' ? brightnessVal : volumeVal) * 100)}%</Text>
          </View>
        )}

        <Animated.View style={[fs.overlay, { opacity: controlsAnim }]} pointerEvents={controlsVisible ? 'box-none' : 'none'}>
          <LinearGradient colors={['rgba(7,7,12,0.92)', 'rgba(7,7,12,0.6)', 'transparent']} locations={[0, 0.55, 1]} style={fs.topGrad} pointerEvents="none" />

          <View style={fs.topBar}>
            <TouchableOpacity style={fs.closeBtn} onPress={onClose}>
              <Ionicons name="chevron-down" size={22} color="#fff" />
            </TouchableOpacity>
            <View style={{ flex: 1, marginLeft: T.space.md }}>
              {title ? <Text style={fs.titleTxt} numberOfLines={1}>{title}</Text> : null}
              {subtitle ? <Text style={fs.subtitleTxt} numberOfLines={1}>{subtitle}</Text> : null}
            </View>
            <View style={fs.topRight}>
              {sources && sources.length > 1 && (
                <>
                  <TouchableOpacity
                    style={fs.iconBtn}
                    onPress={() => setShowSourceSelector(true)}
                  >
                    <Ionicons name="options-outline" size={18} color="#fff" />
                    <View style={fs.sourceBadge}>
                      <Text style={fs.sourceBadgeText}>
                        {currentSourceIndex !== undefined ? currentSourceIndex + 1 : 1}/{sources.length}
                      </Text>
                    </View>
                  </TouchableOpacity>
                  <Modal
                    visible={showSourceSelector}
                    transparent
                    animationType="fade"
                    onRequestClose={() => setShowSourceSelector(false)}
                  >
                    <Pressable style={fs.modalOverlay} onPress={() => setShowSourceSelector(false)}>
                      <View style={fs.modalPanel}>
                        <Text style={fs.modalTitle}>Seleccionar fuente</Text>
                        {sources.map((src, idx) => {
                          const active = currentSourceIndex === idx;
                          return (
                            <TouchableOpacity
                              key={idx}
                              style={[fs.modalOption, active && { backgroundColor: primaryColor + '30', borderColor: primaryColor }]}
                              onPress={() => {
                                onSourceChange?.(idx);
                                setShowSourceSelector(false);
                              }}
                            >
                              <Text style={[fs.modalOptionText, active && { color: primaryColor, fontWeight: '700' }]}>
                                Fuente {idx + 1}
                              </Text>
                              {active && <Ionicons name="checkmark-circle" size={20} color={primaryColor} />}
                            </TouchableOpacity>
                          );
                        })}
                      </View>
                    </Pressable>
                  </Modal>
                </>
              )}
              {canales && canales.length > 0 && (
                <TouchableOpacity style={fs.iconBtn} onPress={() => setShowSidebar(prev => !prev)}>
                  <Ionicons name="list-outline" size={19} color="#fff" />
                </TouchableOpacity>
              )}
              <TouchableOpacity style={fs.iconBtn} onPress={() => setAspect(a => a === 'contain' ? 'fill' : 'contain')}>
                <Ionicons name={aspect === 'contain' ? 'scan-outline' : 'contract-outline'} size={19} color="#fff" />
              </TouchableOpacity>
            </View>
          </View>

          <View style={fs.centerRow} pointerEvents="box-none">
            {!isLive && onPrev && (
              <TouchableOpacity style={fs.navBtn} onPress={onPrev}>
                <Ionicons name="play-skip-back" size={26} color="#fff" />
              </TouchableOpacity>
            )}
            {!isLive && (
              <TouchableOpacity style={fs.seekBigBtn} onPress={() => handleSeekTo(currentTime - 10)}>
                <Ionicons name="play-back" size={24} color="#fff" />
                <Text style={fs.seekBigLabel}>10</Text>
              </TouchableOpacity>
            )}
            {!isLive && (
              <TouchableOpacity style={fs.playPauseBtn} onPress={() => { playerRef.current?.togglePlay(); setIsPlaying(prev => !prev); }}>
                <Ionicons name={isPlaying ? 'pause' : 'play'} size={32} color="#fff" />
              </TouchableOpacity>
            )}
            {!isLive && (
              <TouchableOpacity style={fs.seekBigBtn} onPress={() => handleSeekTo(currentTime + 10)}>
                <Ionicons name="play-forward" size={24} color="#fff" />
                <Text style={fs.seekBigLabel}>10</Text>
              </TouchableOpacity>
            )}
            {!isLive && onNext && (
              <TouchableOpacity style={fs.navBtn} onPress={onNext}>
                <Ionicons name="play-skip-forward" size={26} color="#fff" />
              </TouchableOpacity>
            )}
          </View>

          {!isLive && duration > 0 && (
            <View>
              <LinearGradient colors={['transparent', 'rgba(7,7,12,0.7)', 'rgba(7,7,12,0.95)']} locations={[0, 0.5, 1]} style={fs.bottomGrad} pointerEvents="none" />
              <View style={fs.bottomBar}>
                <Text style={fs.timeTxt}>{formatTime(currentTime)}</Text>
                <View
                  ref={seekBarRef}
                  style={fs.progressTrack}
                  onLayout={(e) => { seekBarWidth.current = e.nativeEvent.layout.width; }}
                  {...seekPanResponder.panHandlers}
                >
                  <View style={fs.progressBg} />
                  <View style={[fs.progressFill, { width: `${progress * 100}%`, backgroundColor: primaryColor }]} />
                  <View style={[fs.progressGlow, { left: `${progress * 100}%`, backgroundColor: primaryColor }]} />
                  <View style={[fs.progressThumb, { left: `${progress * 100}%`, backgroundColor: '#fff', shadowColor: primaryColor }]} />
                </View>
                <Text style={fs.timeTxt}>{formatTime(duration)}</Text>
              </View>
            </View>
          )}
        </Animated.View>

        {/* Sidebar canales */}
        {showSidebar && (
          <TouchableWithoutFeedback onPress={() => setShowSidebar(false)}>
            <View style={fs.sidebarOverlay} pointerEvents="box-none">
              <Animated.View
                style={[
                  fs.sidebarPanel,
                  {
                    transform: [{ translateX: sidebarAnim }],
                    width: panelWidth,
                  }
                ]}
                pointerEvents="auto"
              >
                <View style={fs.sidebarHeader}>
                  <Text style={fs.sidebarTitle}>Canales</Text>
                  <TouchableOpacity onPress={() => setShowSidebar(false)}>
                    <Ionicons name="close" size={24} color="#fff" />
                  </TouchableOpacity>
                </View>
                <FlatList
                  data={canales || []}
                  keyExtractor={item => item.id}
                  renderItem={({ item }) => {
                    const active = canalActual?.id === item.id;
                    return (
                      <TouchableOpacity
                        style={[fs.sidebarItem, active && { backgroundColor: primaryColor + '20', borderColor: primaryColor }]}
                        onPress={() => {
                          onSelectCanal?.(item);
                          setShowSidebar(false);
                        }}
                      >
                        <Text style={[fs.sidebarItemNum, active && { color: primaryColor }]}>
                          {item.numero}
                        </Text>
                        <Text style={[fs.sidebarItemName, active && { color: primaryColor, fontWeight: '700' }]} numberOfLines={1}>
                          {item.name}
                        </Text>
                        {item.category && (
                          <Text style={fs.sidebarItemCat} numberOfLines={1}>
                            {item.category}
                          </Text>
                        )}
                        {favorites?.includes(item.id) && (
                          <Ionicons name="star" size={14} color={T.color.gold} style={{ marginLeft: 'auto' }} />
                        )}
                      </TouchableOpacity>
                    );
                  }}
                  showsVerticalScrollIndicator={false}
                  contentContainerStyle={{ paddingBottom: 20 }}
                />
              </Animated.View>
            </View>
          </TouchableWithoutFeedback>
        )}
      </View>
    </Modal>
  );
});




